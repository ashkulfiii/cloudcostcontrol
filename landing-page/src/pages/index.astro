---
import { getCollection } from 'astro:content';
import Hero from '../components/Hero.astro';
import Services from '../components/Services.astro';
import ValueProposition from '../components/ValueProposition.astro';
import Contact from '../components/Contact.astro';
import Layout from '../layouts/Layout.astro';

// Get latest blog posts
const blogPosts = await getCollection('blog', ({ data }) => {
  return !data.draft;
});

// Sort and get latest 3 posts
const latestPosts = blogPosts
  .sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime())
  .slice(0, 3);
---

<Layout title="C³ - Cloud Cost Control | Azure Cost Optimization Services">
	<Hero />
	<ValueProposition />
	<Services />
	
	<!-- Blog Preview Section -->
	{latestPosts.length > 0 && (
		<section class="blog-preview">
			<div class="container">
				<div class="section-header">
					<h2>Latest Cost Optimization Insights</h2>
					<p>Stay ahead with our expert Azure cost optimization strategies, tips, and real-world case studies.</p>
				</div>
				
				<div class="blog-grid">
					{latestPosts.map((post) => (
						<article class="blog-card">
							{post.data.heroImage && (
								<div class="blog-image">
									<img
										src={post.data.heroImage}
										alt={post.data.title}
										loading="lazy"
									/>
								</div>
							)}
							<div class="blog-content">
								<div class="blog-tags">
									{post.data.tags.slice(0, 2).map((tag) => (
										<span class="blog-tag">#{tag}</span>
									))}
								</div>
								<h3 class="blog-title">
									<a href={`/blog/${post.slug}`}>
										{post.data.title}
									</a>
								</h3>
								<p class="blog-description">
									{post.data.description}
								</p>
								<div class="blog-meta">
									<span class="blog-date">
										{post.data.pubDate.toLocaleDateString('en-US', { 
											year: 'numeric', 
											month: 'short', 
											day: 'numeric' 
										})}
									</span>
									<a href={`/blog/${post.slug}`} class="blog-read-more">
										Read More →
									</a>
								</div>
							</div>
						</article>
					))}
				</div>
				
				<div class="blog-cta">
					<a href="/blog" class="btn-primary">View All Articles</a>
				</div>
			</div>
		</section>
	)}
	
	<Contact />
</Layout>

<style>
/* Blog Preview Section Styles */
.blog-preview {
	padding: 80px 0;
	background: #f8fafc;
}

.blog-preview .container {
	max-width: 1200px;
	margin: 0 auto;
	padding: 0 2rem;
}

.blog-grid {
	display: grid;
	grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
	gap: 2rem;
	margin-bottom: 3rem;
}

.blog-card {
	background: white;
	border-radius: 12px;
	box-shadow: 0 4px 6px rgba(0, 0, 0, 0.05);
	overflow: hidden;
	transition: all 0.3s ease;
	border: 1px solid #e2e8f0;
}

.blog-card:hover {
	transform: translateY(-2px);
	box-shadow: 0 12px 24px rgba(0, 0, 0, 0.1);
}

.blog-image {
	width: 100%;
	height: 200px;
	overflow: hidden;
}

.blog-image img {
	width: 100%;
	height: 100%;
	object-fit: cover;
	transition: transform 0.3s ease;
}

.blog-card:hover .blog-image img {
	transform: scale(1.05);
}

.blog-content {
	padding: 1.5rem;
}

.blog-tags {
	display: flex;
	flex-wrap: wrap;
	gap: 0.5rem;
	margin-bottom: 1rem;
}

.blog-tag {
	background: #dbeafe;
	color: #1e40af;
	padding: 0.25rem 0.75rem;
	border-radius: 20px;
	font-size: 0.75rem;
	font-weight: 500;
}

.blog-title {
	margin: 0 0 1rem 0;
	font-size: 1.25rem;
	font-weight: 700;
	line-height: 1.3;
}

.blog-title a {
	color: #1f2937;
	text-decoration: none;
	transition: color 0.2s ease;
}

.blog-title a:hover {
	color: #2563eb;
}

.blog-description {
	color: #6b7280;
	font-size: 0.9rem;
	line-height: 1.5;
	margin-bottom: 1.5rem;
	display: -webkit-box;
	-webkit-line-clamp: 3;
	-webkit-box-orient: vertical;
	overflow: hidden;
}

.blog-meta {
	display: flex;
	justify-content: space-between;
	align-items: center;
	font-size: 0.8rem;
	color: #9ca3af;
}

.blog-read-more {
	color: #2563eb;
	text-decoration: none;
	font-weight: 500;
	transition: color 0.2s ease;
}

.blog-read-more:hover {
	color: #1d4ed8;
}

.blog-cta {
	text-align: center;
}

/* Responsive Design */
@media (max-width: 768px) {
	.blog-grid {
		grid-template-columns: 1fr;
		gap: 1.5rem;
	}
	
	.blog-preview {
		padding: 60px 0;
	}
	
	.blog-preview .container {
		padding: 0 1rem;
	}
}
</style>
