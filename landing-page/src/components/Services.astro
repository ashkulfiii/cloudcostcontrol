---
// Services section
---

<section id="services" class="services">
	<div class="container">		<div class="section-header">
			<h2>Our Azure Cost Optimization Services</h2>
			<p>Comprehensive solutions designed specifically for finance teams who need clarity and control over their Azure cloud spending.</p>
		</div>

		<div class="services-grid">
			<div class="service-card featured">
				<div class="service-header">
					<div class="service-icon">
						<svg width="32" height="32" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
							<path d="M3 3V21H21" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
							<path d="M9 9L12 6L16 10L20 6L22 8" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
						</svg>
					</div>
					<div class="popular-badge">Most Popular</div>
				</div>
				<h3>Complete Cost Assessment</h3>
				<p class="service-description">Full audit of your current Azure spending with detailed baseline establishment and optimization roadmap.</p>
				<ul class="service-features">
					<li>Comprehensive spend analysis</li>
					<li>Cost baseline establishment</li>
					<li>Optimization recommendations</li>
					<li>ROI projections</li>
					<li>Implementation roadmap</li>
				</ul>
				<div class="service-pricing">
					<span class="price">Starting at $2,500</span>
					<span class="price-period">one-time</span>
				</div>				<a href="#contact" class="service-cta primary">Get Started</a>
			</div>

			<div class="service-card">
				<div class="service-header">
					<div class="service-icon">
						<svg width="32" height="32" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
							<path d="M14 2H6C4.89543 2 4 2.89543 4 4V20C4 21.1046 4.89543 22 6 22H18C19.1046 22 20 21.1046 20 20V8L14 2Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
							<path d="M14 2V8H20" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
							<path d="M16 13H8" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
							<path d="M16 17H8" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
						</svg>
					</div>
				</div>
				<h3>Monthly Reporting</h3>
				<p class="service-description">Detailed monthly reports with cost analysis, trend identification, and actionable recommendations.</p>
				<ul class="service-features">
					<li>Monthly cost breakdown</li>
					<li>Trend analysis</li>
					<li>Budget vs actual reporting</li>
					<li>Anomaly detection</li>
					<li>Executive summaries</li>
				</ul>
				<div class="service-pricing">
					<span class="price">$800</span>
					<span class="price-period">per month</span>
				</div>
				<a href="#contact" class="service-cta">Get Started</a>
			</div>

			<div class="service-card">
				<div class="service-header">
					<div class="service-icon">
						<svg width="32" height="32" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
							<path d="M12 2L13.09 8.26L20 9L13.09 9.74L12 16L10.91 9.74L4 9L10.91 8.26L12 2Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
							<path d="M8 21L9.5 16.5L13 17L9.5 17.5L8 21Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
						</svg>
					</div>
				</div>
				<h3>Budget Framework Setup</h3>
				<p class="service-description">Custom budgeting frameworks designed for your organization's cloud spending patterns.</p>
				<ul class="service-features">
					<li>Custom budget categories</li>
					<li>Forecasting models</li>
					<li>Alert thresholds</li>
					<li>Approval workflows</li>
					<li>Team training</li>
				</ul>
				<div class="service-pricing">
					<span class="price">$1,800</span>
					<span class="price-period">one-time</span>
				</div>
				<a href="#contact" class="service-cta">Get Started</a>
			</div>

			<div class="service-card">
				<div class="service-header">
					<div class="service-icon">
						<svg width="32" height="32" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
							<path d="M22 12H18L15 21L9 3L6 12H2" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
						</svg>
					</div>
				</div>
				<h3>Ongoing Optimization</h3>
				<p class="service-description">Continuous monitoring and optimization of your cloud resources for maximum cost efficiency.</p>
				<ul class="service-features">
					<li>24/7 cost monitoring</li>
					<li>Automated alerts</li>
					<li>Quarterly reviews</li>
					<li>Resource right-sizing</li>
					<li>Reserved instance planning</li>
				</ul>
				<div class="service-pricing">
					<span class="price">$1,200</span>
					<span class="price-period">per month</span>
				</div>
				<a href="#contact" class="service-cta">Get Started</a>
			</div>
		</div>

		<div class="custom-solutions">
			<h3>Need a Custom Solution?</h3>
			<p>Every organization has unique cloud cost challenges. We create tailored solutions that fit your specific needs, budget, and timeline.</p>
			<a href="#contact" class="btn-custom">Discuss Your Needs</a>
		</div>
	</div>
</section>

<style>
	.services {
		padding: 100px 0;
		background: white;
	}

	.container {
		max-width: 1200px;
		margin: 0 auto;
		padding: 0 24px;
	}

	.section-header {
		text-align: center;
		margin-bottom: 80px;
	}

	.section-header h2 {
		font-size: 2.5rem;
		font-weight: 700;
		color: #1f2937;
		margin: 0 0 16px;
	}

	.section-header p {
		font-size: 1.25rem;
		color: #6b7280;
		max-width: 600px;
		margin: 0 auto;
	}
	.services-grid {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: 24px;
		margin-bottom: 80px;
	}
	.service-card {
		background: white;
		border: 2px solid #e5e7eb;
		border-radius: 16px;
		padding: 32px 24px;
		transition: all 0.3s ease;
		position: relative;
		display: flex;
		flex-direction: column;
		height: 100%;
	}

	.service-card:hover {
		border-color: #667eea;
		transform: translateY(-4px);
		box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1);
	}

	.service-card.featured {
		border-color: #667eea;
		border-width: 3px;
		background: linear-gradient(135deg, rgba(102, 126, 234, 0.05) 0%, rgba(118, 75, 162, 0.05) 100%);
	}

	.service-header {
		display: flex;
		justify-content: space-between;
		align-items: flex-start;
		margin-bottom: 24px;
	}

	.service-icon {
		color: #667eea;
		background: rgba(102, 126, 234, 0.1);
		padding: 12px;
		border-radius: 12px;
	}

	.popular-badge {
		background: #667eea;
		color: white;
		padding: 4px 12px;
		border-radius: 20px;
		font-size: 0.75rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.05em;
	}

	.service-card h3 {
		font-size: 1.5rem;
		font-weight: 600;
		color: #1f2937;
		margin: 0 0 12px;
	}

	.service-description {
		color: #6b7280;
		margin: 0 0 24px;
		line-height: 1.6;
	}

	.service-features {
		list-style: none;
		padding: 0;
		margin: 0 0 32px;
	}

	.service-features li {
		color: #374151;
		margin: 8px 0;
		padding-left: 24px;
		position: relative;
	}

	.service-features li::before {
		content: '✓';
		color: #10b981;
		font-weight: bold;
		position: absolute;
		left: 0;
	}
	.service-pricing {
		margin-bottom: 24px;
		margin-top: auto;
	}

	.price {
		font-size: 2rem;
		font-weight: 700;
		color: #1f2937;
	}

	.price-period {
		color: #6b7280;
		font-size: 0.9rem;
		margin-left: 8px;
	}

	.service-cta {
		display: block;
		text-align: center;
		padding: 12px 24px;
		border-radius: 8px;
		text-decoration: none;
		font-weight: 600;
		transition: all 0.3s ease;
		border: 2px solid #667eea;
		color: #667eea;
	}

	.service-cta:hover {
		background: #667eea;
		color: white;
	}

	.service-cta.primary {
		background: #667eea;
		color: white;
	}

	.service-cta.primary:hover {
		background: #5b6fd8;
	}

	.custom-solutions {
		background: #f9fafb;
		padding: 48px;
		border-radius: 16px;
		text-align: center;
	}

	.custom-solutions h3 {
		font-size: 1.75rem;
		font-weight: 600;
		color: #1f2937;
		margin: 0 0 16px;
	}

	.custom-solutions p {
		color: #6b7280;
		font-size: 1.125rem;
		margin: 0 0 32px;
		max-width: 600px;
		margin-left: auto;
		margin-right: auto;
	}

	.btn-custom {
		display: inline-block;
		background: #667eea;
		color: white;
		padding: 16px 32px;
		border-radius: 8px;
		text-decoration: none;
		font-weight: 600;
		transition: all 0.3s ease;
	}

	.btn-custom:hover {
		background: #5b6fd8;
		transform: translateY(-2px);
	}
	@media (max-width: 1024px) {
		.services-grid {
			grid-template-columns: repeat(2, 1fr);
			gap: 20px;
		}
	}

	@media (max-width: 768px) {
		.services {
			padding: 80px 0;
		}

		.section-header {
			margin-bottom: 60px;
		}

		.section-header h2 {
			font-size: 2rem;
		}

		.section-header p {
			font-size: 1.125rem;
		}

		.services-grid {
			grid-template-columns: 1fr;
			gap: 20px;
			margin-bottom: 60px;
		}

		.service-card {
			padding: 28px 20px;
		}

		.custom-solutions {
			padding: 40px 24px;
		}

		.custom-solutions h3 {
			font-size: 1.5rem;
		}

		.custom-solutions p {
			font-size: 1rem;
		}
	}
</style>
