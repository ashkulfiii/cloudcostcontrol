---
// Hero section for cloud cost control consultancy
---

<section class="hero">
	<div class="container">
		<div class="hero-content">
			<h1>Take Control of Your Azure Cloud Costs</h1>			
            <p class="hero-subtitle">
				Professional Azure cost optimization services that help finance teams establish clear baselines, 
				create actionable budgets, and maintain predictable cloud spending through strategic reporting and analysis.
			</p>
			<div class="hero-stats">
				<div class="stat">
					<span class="stat-number">30%</span>
					<span class="stat-label">Average Cost Reduction</span>
				</div>				<div class="stat">
					<span class="stat-number">100%</span>
					<span class="stat-label">Spending Visibility</span>
				</div>
				<div class="stat">
					<span class="stat-number">0</span>
					<span class="stat-label">Surprises</span>
				</div></div>
			<div class="hero-cta">
				<a href="#contact" class="btn-primary">Schedule Your Free Assesment</a>
				<a href="#services" class="btn-secondary">Learn More</a>
			</div>
		</div>
		<div class="hero-visual">
			<div class="cost-chart">
				<div class="chart-bars">
					<div class="bar" style="height: 80%"></div>
					<div class="bar" style="height: 60%"></div>
					<div class="bar" style="height: 90%"></div>
					<div class="bar" style="height: 45%"></div>
					<div class="bar" style="height: 80%"></div>
					<div class="bar optimized" style="height: 60%"></div>
					<div class="bar optimized" style="height: 62%"></div>
					<div class="bar optimized" style="height: 64%"></div>
					<div class="bar optimized" style="height: 66%"></div>
					<div class="bar optimized" style="height: 64%"></div>
					<div class="bar optimized" style="height: 68%"></div>                                                                              				</div>
				<div class="chart-label">Before vs After Optimization</div>
			</div>
		</div>
	</div>
</section>

<style>
	.hero {
		background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
		color: white;
		padding: 100px 0 80px;
		position: relative;
		overflow: hidden;
	}

	.hero::before {
		content: '';
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		bottom: 0;
		background: rgba(0, 0, 0, 0.1);
		pointer-events: none;
	}

	.container {
		max-width: 1200px;
		margin: 0 auto;
		padding: 0 24px;
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 80px;
		align-items: center;
		position: relative;
		z-index: 1;
	}

	.hero-content h1 {
		font-size: 3.5rem;
		font-weight: 700;
		line-height: 1.1;
		margin: 0 0 24px;
	}

	.hero-subtitle {
		font-size: 1.25rem;
		line-height: 1.6;
		margin: 0 0 40px;
		opacity: 0.95;
	}

	.hero-stats {
		display: flex;
		gap: 40px;
		margin: 40px 0;
	}

	.stat {
		text-align: center;
	}

	.stat-number {
		display: block;
		font-size: 2.5rem;
		font-weight: 700;
		color: #fbbf24;
	}

	.stat-label {
		display: block;
		font-size: 0.9rem;
		opacity: 0.9;
		margin-top: 4px;
	}

	.hero-cta {
		display: flex;
		gap: 16px;
		flex-wrap: wrap;
	}

	.btn-primary, .btn-secondary {
		padding: 16px 32px;
		border-radius: 8px;
		font-weight: 600;
		text-decoration: none;
		transition: all 0.3s ease;
		display: inline-block;
	}

	.btn-primary {
		background: #fbbf24;
		color: #1f2937;
	}

	.btn-primary:hover {
		background: #f59e0b;
		transform: translateY(-2px);
	}

	.btn-secondary {
		background: transparent;
		color: white;
		border: 2px solid white;
	}

	.btn-secondary:hover {
		background: white;
		color: #667eea;
	}

	.hero-visual {
		display: flex;
		justify-content: center;
		align-items: center;
	}
	.cost-chart {
		background: rgba(255, 255, 255, 0.1);
		backdrop-filter: blur(10px);
		border-radius: 16px;
		padding: 32px;
		border: 1px solid rgba(255, 255, 255, 0.2);
		width: 100%;
		max-width: 100%;
		overflow: hidden;
	}

	.chart-bars {
		display: flex;
		align-items: end;
		gap: 12px;
		height: 200px;
		margin-bottom: 16px;
		justify-content: space-between;
		max-width: 100%;
	}

	.bar {
		width: 32px;
		min-width: 20px;
		flex: 1;
		max-width: 40px;
		background: rgba(255, 255, 255, 0.6);
		border-radius: 4px 4px 0 0;
		transition: all 0.3s ease;
	}

	.bar.optimized {
		background: #10b981;
	}

	.chart-label {
		text-align: center;
		font-size: 0.9rem;
		opacity: 0.9;
		white-space: nowrap;
		overflow: hidden;
		text-overflow: ellipsis;
	}	@media (max-width: 768px) {
		.container {
			grid-template-columns: 1fr;
			gap: 40px;
			text-align: center;
			padding: 0 24px;
		}

		.cost-chart {
			padding: 24px;
			max-width: 100%;
		}

		.chart-bars {
			gap: 8px;
			height: 150px;
		}

		.bar {
			width: 20px;
			min-width: 15px;
			max-width: 25px;
		}

		.chart-label {
			font-size: 0.8rem;
		}

		.hero-content h1 {
			font-size: 2.2rem;
			line-height: 1.2;
			margin-bottom: 20px;
		}

		.hero-subtitle {
			font-size: 1.1rem;
			line-height: 1.5;
			margin-bottom: 32px;
		}

		.hero-stats {
			justify-content: center;
			gap: 24px;
		}

		.hero-cta {
			justify-content: center;
		}

		.btn-primary, .btn-secondary {
			padding: 14px 24px;
		}
	}

	@media (max-width: 480px) {
		.hero {
			padding: 80px 0 60px;
		}

		.container {
			padding: 0 20px;
		}

		.cost-chart {
			padding: 20px;
		}

		.chart-bars {
			gap: 6px;
			height: 120px;
		}

		.bar {
			width: 16px;
			min-width: 12px;
			max-width: 20px;
		}

		.chart-label {
			font-size: 0.75rem;
		}

		.hero-content h1 {
			font-size: 1.8rem;
			line-height: 1.3;
			margin-bottom: 16px;
		}

		.hero-subtitle {
			font-size: 1rem;
			line-height: 1.6;
			margin-bottom: 28px;
		}

		.hero-stats {
			flex-direction: column;
			gap: 16px;
		}

		.stat-number {
			font-size: 2rem;
		}

		.hero-cta {
			flex-direction: column;
			align-items: center;
		}

		.btn-primary, .btn-secondary {
			width: 100%;
			max-width: 280px;
		}
	}
</style>
